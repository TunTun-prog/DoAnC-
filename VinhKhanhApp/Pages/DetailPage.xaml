<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VinhKhanhApp.Pages.DetailPage">

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="10">

			<Label
                x:Name="NameLabel"
                FontSize="22"
                FontAttributes="Bold"/>

			<Label
                x:Name="DescLabel"
                FontSize="16"/>

			<Label
                x:Name="RatingLabel"
                FontSize="16"/>

			<Button
                x:Name="DirectionBtn"
                Text="Direction"
                Clicked="OnDirection"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>