<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="VinhKhanhApp.Pages.LanguagePage">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Label Text="Chọn ngôn ngữ / Select Language"
               FontSize="22"
               HorizontalOptions="Center"/>

        <Button Text="🇻🇳 Tiếng Việt" Clicked="OnVN"/>
        <Button Text="🇬🇧 English" Clicked="OnEN"/>
        <Button Text="🇩🇪 Deutsch" Clicked="OnDE"/>
        <Button Text="🇯🇵 日本語" Clicked="OnJP"/>
        <Button Text="🇨🇳 中文" Clicked="OnZH"/>

    </VerticalStackLayout>
</ContentPage>