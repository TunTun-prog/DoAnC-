@model AdminSystem.Models.QuayHang

@{
    ViewData["Title"] = "Chi tiết quầy hàng";
}

<h1>Chi tiết quầy hàng</h1>

<div class="row align-items-stretch">
    <div class="col-md-7 d-flex">
        <div class="card w-100">
            <div class="card-body" style="min-height:280px; overflow:auto;">
                <h4 class="card-title">@Html.DisplayFor(m => m.Ten)</h4>

                <h6>Mô tả</h6>
                <p class="card-text">@Html.DisplayFor(m => m.MoTa)</p>

                <h6>Thông tin</h6>
                <dl class="row">
                    <dt class="col-sm-3">Vị trí (miêu tả)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.ViTri)</dd>

                    <dt class="col-sm-3">Địa chỉ</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.DiaChi)</dd>

                    <dt class="col-sm-3">Người quản lý</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.NguoiQuanLy)</dd>

                    <dt class="col-sm-3">Tạo lúc</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.CreatedUtc)</dd>
                </dl>

                <h6>Thuyết trình (audio)</h6>
                @if (!string.IsNullOrEmpty(Model?.AudioPath))
                {
                    <audio controls style="width:100%">
                        <source src="@Model.AudioPath" />
                        Trình duyệt không hỗ trợ audio.
                    </audio>
                    <p class="text-muted mt-2">Mô tả: @Html.DisplayFor(m => m.MoTa)</p>
                }
                else
                {
                    <div class="text-muted">Không có audio thuyết trình.</div>
                }

                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Chỉnh sửa</a>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5 d-flex flex-column">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">Map Preview</h6>
                <div id="map" style="height:280px;"></div>
                <small class="text-muted">Bản đồ vị trí quầy hàng</small>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h6 class="card-title">Ảnh bìa</h6>
                @if (!string.IsNullOrEmpty(Model?.CoverImagePath))
                {
                    <img src="@Model.CoverImagePath" class="img-fluid" style="width:100%; max-height:220px; object-fit:cover;" />
                }
                else
                {
                    <div class="text-muted">Chưa có ảnh bìa.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script>
        (function () {
            var lat = @((Model.Latitude ?? 0.0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            var lng = @((Model.Longitude ?? 0.0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            var hasCoord = parseFloat(lat) !== 0 || parseFloat(lng) !== 0;
            var defaultLat = hasCoord ? parseFloat(lat) : 10.762622;
            var defaultLng = hasCoord ? parseFloat(lng) : 106.660172;
            var center = [defaultLat, defaultLng];

            var map = L.map('map').setView(center, hasCoord ? 16 : 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            if (hasCoord) {
                L.marker(center).addTo(map)
                    .bindPopup('@(Model.Ten?.Replace("'", "\\'") ?? "")')
                    .openPopup();
            }
        })();
    </script>
}
