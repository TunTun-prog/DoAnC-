@model AdminSystem.Models.QuayHang

@{
    ViewData["Title"] = "Chỉnh sửa quầy hàng";
}

<h1>Chỉnh sửa quầy hàng</h1>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Tên</label>
                <input asp-for="Ten" class="form-control" />
                <span asp-validation-for="Ten" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Vị trí (miêu tả)</label>
                <input asp-for="ViTri" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Người quản lý</label>
                <input asp-for="NguoiQuanLy" class="form-control" />
            </div>

            <hr />
            <h5>Ảnh bìa</h5>

            <div class="mb-3">
                <label class="form-label">Cover Image</label>
                <input type="file" name="coverImage" id="coverImage" class="form-control" accept="image/*" />
                <div class="mt-2">
                    @if (!string.IsNullOrEmpty(Model?.CoverImagePath))
                    {
                        <img id="coverPreview" src="@Model.CoverImagePath" alt="Cover" class="img-fluid" style="max-height:140px;" />
                    }
                    else
                    {
                        <img id="coverPreview" src="" alt="" class="img-fluid" style="max-height:140px; display:none;" />
                    }
                </div>
            </div>

            <hr />
            <h5>Audio thuyết trình</h5>

            <div class="mb-3">
                <label class="form-label">File audio (thay thế)</label>
                <input type="file" name="audioFile" id="audioFile" class="form-control" accept="audio/*" />
                <div class="mt-2">
                    @if (!string.IsNullOrEmpty(Model?.AudioPath))
                    {
                        <audio id="audioExisting" controls style="width:100%">
                            <source src="@Model.AudioPath" />
                            Your browser does not support the audio element.
                        </audio>
                    }
                    <audio id="audioPreview" controls style="display:none; width:100%"></audio>
                </div>
            </div>

            <hr />
            <h5>Địa điểm</h5>

            <div class="mb-3">
                <label class="form-label">Địa chỉ</label>
                <div class="input-group">
                    <input asp-for="DiaChi" id="diachi" class="form-control" />
                    <button type="button" id="btnSearch" class="btn btn-outline-secondary">Tìm</button>
                </div>
                <span asp-validation-for="DiaChi" class="text-danger"></span>
            </div>

            <input asp-for="Latitude" id="latitude" type="hidden" />
            <input asp-for="Longitude" id="longitude" type="hidden" />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>

    <div class="col-md-5">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">Map Preview & Location Picker</h6>
                <div id="map" style="height:340px;"></div>
                <small class="text-muted">Nhấp lên bản đồ để chọn vị trí; kéo marker để chỉnh vị trí.</small>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h6 class="card-title">Ảnh hiện tại</h6>
                @if (!string.IsNullOrEmpty(Model?.CoverImagePath))
                {
                    <img src="@Model.CoverImagePath" class="img-fluid" style="width:100%; max-height:200px; object-fit:cover;" />
                }
                else
                {
                    <div class="text-muted">Chưa có ảnh bìa.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script>
        // Cover image preview client-side
        document.getElementById('coverImage').addEventListener('change', function (e) {
            var file = e.target.files[0];
            var img = document.getElementById('coverPreview');
            if (!file) { img.style.display = 'none'; img.src = ''; return; }
            var url = URL.createObjectURL(file);
            img.src = url;
            img.style.display = 'block';
        });

        // audio preview (replace existing preview when selecting a new file)
        document.getElementById('audioFile').addEventListener('change', function (e) {
            var file = e.target.files[0];
            var audio = document.getElementById('audioPreview');
            var audioExisting = document.getElementById('audioExisting');
            if (audioExisting) audioExisting.style.display = 'none';
            if (!file) { audio.style.display = 'none'; audio.src = ''; return; }
            var url = URL.createObjectURL(file);
            audio.src = url; audio.style.display = 'block';
        });

        (function () {
            function toFixedInvariant(v) { return v.toFixed(6); }

            var latVal = @((Model?.Latitude ?? 0.0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            var lngVal = @((Model?.Longitude ?? 0.0).ToString(System.Globalization.CultureInfo.InvariantCulture));
            var hasCoord = parseFloat(latVal) !== 0 || parseFloat(lngVal) !== 0;
            var defaultLat = hasCoord ? parseFloat(latVal) : 10.762622;
            var defaultLng = hasCoord ? parseFloat(lngVal) : 106.660172;
            var center = [defaultLat, defaultLng];

            var map = L.map('map').setView(center, 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            var marker = L.marker(center, { draggable: true }).addTo(map);

            if (!hasCoord) {
                // Hide marker initially until user picks or drags (optional)
                marker.setOpacity(0.6);
            }

            function updateInputs(latlng) {
                document.getElementById('latitude').value = toFixedInvariant(latlng.lat);
                document.getElementById('longitude').value = toFixedInvariant(latlng.lng);
            }

            marker.on('dragend', function (e) { updateInputs(e.target.getLatLng()); marker.setOpacity(1); });

            map.on('click', function (e) {
                marker.setLatLng(e.latlng);
                updateInputs(e.latlng);
                marker.setOpacity(1);
            });

            document.getElementById('btnSearch').addEventListener('click', function () {
                var q = document.getElementById('diachi').value;
                if (!q) return;
                fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(q))
                    .then(r => r.json())
                    .then(data => {
                        if (!data || data.length === 0) { alert('Không tìm thấy địa chỉ.'); return; }
                        var p = data[0];
                        var latlng = L.latLng(parseFloat(p.lat), parseFloat(p.lon));
                        map.setView(latlng, 17);
                        marker.setLatLng(latlng);
                        updateInputs(latlng);
                        document.getElementById('diachi').value = p.display_name || document.getElementById('diachi').value;
                        marker.setOpacity(1);
                    })
                    .catch(() => alert('Lỗi khi tìm địa chỉ.'));
            });
        })();
    </script>
}
