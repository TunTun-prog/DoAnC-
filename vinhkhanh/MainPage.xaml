<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="vinhkhanh.MainPage">

    <CollectionView x:Name="listView">

        <CollectionView.ItemTemplate>
            <DataTemplate>

                <Border Stroke="Gray"
                        Padding="10"
                        StrokeShape="RoundRectangle 15">

                    <VerticalStackLayout Spacing="10">

                        <Label Text="{Binding Name}"
                               FontAttributes="Bold"
                               FontSize="18"/>

                        <Image Source="{Binding Image1}" HeightRequest="120"/>

                        <Label Text="{Binding Address}" FontSize="12"/>
                        <Label Text="{Binding Rating, StringFormat='⭐ {0}/5'}"/>

                        <HorizontalStackLayout Spacing="10">

                            <Button Text="▶"
                                    Clicked="OnPlayClicked"
                                    CommandParameter="{Binding .}"/>

                            <Button Text="📍"
                                    Clicked="OnNavigateClicked"
                                    CommandParameter="{Binding .}"/>

                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                </Border>

            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>